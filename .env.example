# Intellog Environment Configuration
# Copy to .env and update values

# Backend
INTELLOG_SECRET_KEY=change-this-to-random-string
INTELLOG_SERVER=https://intellog.dev
DATABASE_URL=sqlite:///data/intellog.db

# Cloud mode: mock or openstack
CLOUD_MODE=mock

# OpenStack (only if CLOUD_MODE=openstack)
OS_AUTH_URL=http://controller:5000/v3
OS_PROJECT_NAME=intellog
OS_USERNAME=admin
OS_PASSWORD=
OS_USER_DOMAIN=Default
OS_PROJECT_DOMAIN=Default

# Agent
AGENT_INTERVAL=60
